{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://volt-pos/schemas/payment.schema.json",
  "title": "PaymentResponse",
  "type": "object",
  "required": ["id", "status", "amount", "currency", "method", "orderId", "createdAt", "updatedAt"],
  "properties": {
    "id":        { "type": "string", "minLength": 1 },
    "status":    { "type": "string", "enum": ["PENDING", "AUTHORIZED", "CAPTURED", "SETTLED", "FAILED", "REFUNDED", "CANCELLED"] },
    "amount":    { "type": "number", "minimum": 0 },
    "currency":  { "type": "string", "pattern": "^[A-Z]{3}$" },
    "method":    { "type": "string", "enum": ["CARD", "QR", "CASH", "WALLET", "BANK_TRANSFER"] },
    "orderId":   { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "reference": { "type": "string" }
  },
  "additionalProperties": true
}
