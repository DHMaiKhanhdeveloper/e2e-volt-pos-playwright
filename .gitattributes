# Force LF in the repo for all text files so Windows/macOS/Linux check out
# the same content. Windows working copies may still appear as CRLF locally
# depending on core.autocrlf — Prettier "endOfLine: auto" tolerates both.
* text=auto eol=lf

# Lockfiles — keep LF, never auto-detect as binary
package-lock.json text eol=lf
*.json            text eol=lf
*.yml             text eol=lf
*.yaml            text eol=lf
*.md              text eol=lf
*.ts              text eol=lf
*.tsx             text eol=lf
*.js              text eol=lf
*.mjs             text eol=lf
*.cjs             text eol=lf

# Shell / batch scripts
*.sh              text eol=lf
*.bat             text eol=crlf
*.cmd             text eol=crlf
*.ps1             text eol=crlf

# Binary — never normalise
*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.ico             binary
*.pdf             binary
*.zip             binary
