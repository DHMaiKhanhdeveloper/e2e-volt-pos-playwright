# =====================================================
# Sample env file — copy to .env.local / .env.stage / .env.prod
# DO NOT commit real credentials. Real env files are in .gitignore.
# =====================================================

# Runtime
ENV=local
HEADLESS=true
SLOW_MO=0

# Volt POS app
BASE_URL=http://localhost:1420
GRAPHQL_URL=http://localhost:1420/graphql
API_TIMEOUT=30000

# Owner/tenant passcode used to authorize payment completion in the passcode dialog
OWNER_PASSCODE=0123

# Logging
LOG_LEVEL=info

# =====================================================
# Optional — Claude Code MCP integration (see README.md → Working with Claude Code)
# Required only if you use the GitHub MCP server in .mcp.json.
# Set this in your SHELL before launching Claude — do NOT commit a real token.
# =====================================================
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_replace_me
