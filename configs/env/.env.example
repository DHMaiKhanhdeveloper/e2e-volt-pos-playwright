# =====================================================
# Sample env file — copy to .env.local / .env.stage / .env.prod
# DO NOT commit real credentials. Real env files are in .gitignore.
# =====================================================

# Runtime
ENV=local
HEADLESS=true
SLOW_MO=0

# Web
BASE_URL=https://pos.local.example.com
LOGIN_PATH=/auth/login
DASHBOARD_PATH=/dashboard

# API
API_BASE_URL=https://api.local.example.com
API_VERSION=v1
API_TIMEOUT=30000

# Test users (override via secret manager in CI)
ADMIN_USER=admin@example.com
ADMIN_PASS=ChangeMe!123
CASHIER_USER=cashier@example.com
CASHIER_PASS=ChangeMe!123

# Payment gateway sandbox
PAYMENT_GATEWAY_URL=https://sandbox.payment.example.com
PAYMENT_MERCHANT_ID=TEST_MERCHANT_001
PAYMENT_API_KEY=sandbox_key_replace_me

# DB / data services (optional — only if tests touch DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=volt_pos_test
DB_USER=test
DB_PASS=test

# Reporting
ALLURE_RESULTS_DIR=reports/allure-results
LOG_LEVEL=info
